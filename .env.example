# ===========================================
# AI Mock Interview - Environment Variables
# ===========================================

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DATABASE_SSL=false
# Set true ONLY if TLS cert verification is impossible (proxy/self-signed).
# Disables MITM protection on the DB link — avoid in production.
# DATABASE_SSL_INSECURE=false

# Groq API (LLM + Speech-to-Text)
# Get your key from https://console.groq.com
# Used for: Question generation, answer evaluation, Whisper transcription
GROQ_API_KEY=gsk_your_key_here

# Google Gemini (optional fallback LLM). When set, a Groq outage/circuit-open
# degrades to Gemini instead of failing. Get a key from https://aistudio.google.com
GOOGLE_GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# Health endpoint: token that unlocks the detailed /api/health telemetry
# (DB latency, circuit state, version). Anonymous callers get coarse up/down only.
HEALTH_STATUS_TOKEN=

# Admin Configuration
# The email address that will be auto-approved as admin on signup
ADMIN_EMAIL=admin@example.com

# Redis (self-hosted on same VPS; used for rate limiting + cache)
# Leave as localhost:6379 for typical deployments.
# `apt install redis-server` is the minimum setup.
REDIS_URL=redis://localhost:6379

# CSRF Protection
CSRF_ENFORCE=true

# Trusted reverse-proxy hops in front of the app (nginx = 1; 0 for local dev).
# Determines how the real client IP is derived so X-Forwarded-For can't be
# spoofed to bypass rate limits. Requires nginx to set X-Real-IP + X-Forwarded-For.
TRUSTED_PROXY_HOPS=1

# Per-user AI cost caps (per UTC day). Optional — defaults shown.
AI_DAILY_QUOTA=150
AI_TRANSCRIBE_DAILY_QUOTA=600
# Hard kill-switch for all AI features during a cost/provider emergency.
AI_DISABLED=false

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
